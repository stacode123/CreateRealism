{
  "schemaVersion": 1,
  "id": "realism",
  "version": "${version}",
  "name": "Create Realism",
  "description": "A mod changing the Trains in create to be more realistic",
  "authors": [
    "Stacode"
  ],
  "contact": {
    "sources": "https://github.com/stacode123/CreateRealism"
  },
  "license": "MIT",
  "icon": "assets/realism/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.Realism.fabric.RealismFabric"
    ],
    "fabric-datagen": [
      "net.Realism.datagen.DataGenEntry"
    ]
  },
  "mixins": [
    "realismFabric.mixins.json",
    "realismCommon.mixins.json"
  ],
  "depends": {
    "minecraft": "${minecraft_version}",
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "create": ">=${create_version}",
    "architectury": ">=${architectury_version}",
    "dragonlib": ">=${minecraft_version}-${dragonlib_version}"
  },
  "recommends": {
    "tramways": ">=${tramways_version}"
  }
}
